@article{meyer-gohde_2026_frequency,
title = {Solving and analyzing DSGE models in the frequency domain},
journal = {Journal of Economic Dynamics and Control},
volume = {185},
pages = {1--27},
year = {2026},
issn = {0165-1889},
doi = {https://doi.org/10.1016/j.jedc.2026.105281},
url = {https://www.sciencedirect.com/science/article/pii/S0165188926000278},
author = {Alexander Meyer-Gohde},
keywords = {DSGE, Solution methods, Spectral methods, Bayesian estimation, General exogenous processes},
abstract = {I solve multivariate linear rational expectations models in the frequency domain using the generalized Schur decomposition, providing a numerical implementation suitable for standard DSGE estimation and analysis procedures. This approach generalizes the time domain restriction of autoregressive-moving average exogenous driving forces to arbitrary covariance stationary processes. Applied to the standard New Keynesian model, I find that a Bayesian analysis favors a single parameter log harmonic function of the lag operator over the usual AR(1) assumption as it generates hump shaped autocorrelation patterns more consistent with the data.}
}
